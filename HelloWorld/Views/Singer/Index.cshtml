@model IEnumerable<HelloWorld.Models.Singer>
@{ ViewData["Title"] = "Ca sĩ"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Danh sách ca sĩ</h1>
    <a asp-action="Create" class="btn btn-primary">+ Thêm ca sĩ</a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<table class="table table-bordered table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th style="width:90px">Ảnh</th>
            <th>Tên ca sĩ</th>
            <th>Số bài hát</th>
            <th style="width:220px"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" alt="@item.Name"
                             style="width:80px;height:80px;object-fit:cover" class="rounded-circle"/>
                    }
                    else
                    {
                        <div class="bg-light rounded-circle d-flex align-items-center justify-content-center"
                             style="width:80px;height:80px;font-size:11px;color:#aaa">
                            <i class="bi bi-person fs-3 text-secondary"></i>
                        </div>
                    }
                </td>
                <td class="fw-semibold">@item.Name</td>
                <td>
                    <span class="badge bg-primary">@item.Songs.Count bài</span>
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Chi tiết</a>
                    <a asp-action="Edit"    asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                    <form method="post" action="@Url.Action("Delete", new { id = item.Id })" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-danger"
                                data-name="@item.Name"
                                onclick="return confirm('Xóa ca sĩ &quot;' + this.dataset.name + '&quot;?')">Xóa</button>
                    </form>
                </td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr>
                <td colspan="4" class="text-center text-muted py-4">Chưa có ca sĩ nào.</td>
            </tr>
        }
    </tbody>
</table>
