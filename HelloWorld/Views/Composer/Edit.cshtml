@model HelloWorld.Models.Composer
@{ ViewData["Title"] = "Sửa nhạc sĩ"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Sửa nhạc sĩ</h1>
    <a asp-action="Index" class="btn btn-secondary">← Quay lại</a>
</div>

<form asp-action="Edit" method="post" enctype="multipart/form-data" style="max-width:720px">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
    <input type="hidden" asp-for="Id"/>

    <div class="mb-3">
        <label asp-for="Name" class="form-label fw-semibold">Tên nhạc sĩ <span class="text-danger">*</span></label>
        <input asp-for="Name" class="form-control"/>
        <span asp-validation-for="Name" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Ảnh đại diện</label>
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <div class="mb-2">
                <img src="@Model.ImageUrl" alt="@Model.Name"
                     style="width:120px;height:120px;object-fit:cover;border-radius:50%" id="previewImg"/>
            </div>
        }
        else
        {
            <div class="mb-2" id="imagePreview" style="display:none">
                <img id="previewImg" src="#" alt="Preview"
                     style="width:120px;height:120px;object-fit:cover;border-radius:50%"/>
            </div>
        }
        <input type="file" name="imageFile" id="imageFile" class="form-control" accept="image/*"
               onchange="previewImage(this)"/>
        <div class="form-text">Để trống nếu không muốn thay đổi ảnh.</div>
    </div>

    <div class="mb-3">
        <label asp-for="Biography" class="form-label fw-semibold">Tiểu sử</label>
        <textarea id="Biography" name="Biography" class="form-control">@Model.Biography</textarea>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary px-4">Lưu thay đổi</button>
        <a asp-action="Index" class="btn btn-secondary">Hủy</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
    <link rel="stylesheet" href="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.css" crossorigin="anonymous"/>
    <script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js" crossorigin="anonymous"></script>
    <script>
        ClassicEditor.create(document.querySelector('#Biography')).catch(err => console.error(err));

        function previewImage(input) {
            const img = document.getElementById('previewImg');
            const preview = document.getElementById('imagePreview');
            if (input.files && input.files[0]) {
                img.src = URL.createObjectURL(input.files[0]);
                if (preview) preview.style.display = 'block';
            }
        }
    </script>
}
