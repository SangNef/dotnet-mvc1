@model HelloWorld.Models.Composer
@{ ViewData["Title"] = Model.Name; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">@Model.Name</h1>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Sửa</a>
        <a asp-action="Index" class="btn btn-secondary">← Quay lại</a>
    </div>
</div>

<div class="row">
    <div class="col-md-3 text-center mb-4">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Name"
                 style="width:200px;height:200px;object-fit:cover" class="rounded-circle shadow"/>
        }
        else
        {
            <div class="bg-light rounded-circle d-flex align-items-center justify-content-center mx-auto"
                 style="width:200px;height:200px">
                <i class="bi bi-music-note-beamed" style="font-size:80px;color:#ccc"></i>
            </div>
        }
        <h4 class="mt-3">@Model.Name</h4>
    </div>

    <div class="col-md-9">
        @if (!string.IsNullOrEmpty(Model.Biography))
        {
            <div class="card mb-4">
                <div class="card-header fw-semibold">Tiểu sử</div>
                <div class="card-body">@Html.Raw(Model.Biography)</div>
            </div>
        }

        <h5>Bài hát sáng tác (@Model.Songs.Count)</h5>
        @if (Model.Songs.Any())
        {
            <table class="table table-sm table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Tiêu đề</th>
                        <th>Ca sĩ</th>
                        <th>Ngày phát hành</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var song in Model.Songs)
                    {
                        <tr>
                            <td>@song.Title</td>
                            <td>@(song.Singer?.Name ?? "—")</td>
                            <td>@(song.ReleaseDate.HasValue ? song.ReleaseDate.Value.ToString("dd/MM/yyyy") : "—")</td>
                            <td>
                                <a asp-controller="Song" asp-action="Details" asp-route-id="@song.Id"
                                   class="btn btn-sm btn-outline-info">Chi tiết</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">Chưa có bài hát nào.</p>
        }
    </div>
</div>
