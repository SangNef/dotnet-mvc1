@{
    ViewData["Title"] = "Home Page";
}

<!-- Hero -->
<section class="hw-hero d-flex align-items-center justify-content-center text-center">
    <div>
        <span class="hw-badge mb-3 d-inline-block">ASP.NET Core &middot; Bootstrap 5</span>
        <h1 class="hw-hero-title">Hello, <span class="hw-gradient-text">World</span></h1>
        <p class="hw-hero-sub">A clean starting point for your next big idea.</p>
        <div class="mt-4 d-flex gap-3 justify-content-center flex-wrap">
            <a href="https://learn.microsoft.com/aspnet/core" class="btn hw-btn-primary">Get Started</a>
            <a asp-controller="Home" asp-action="Privacy" class="btn hw-btn-outline">Learn More</a>
        </div>
    </div>
</section>

<!-- Features -->
<section class="py-5 mt-2">
    <div class="container">
        <h2 class="text-center fw-semibold mb-1">What&rsquo;s included</h2>
        <p class="text-center text-muted mb-5">Everything you need to build fast, reliable web apps.</p>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="hw-card h-100">
                    <div class="hw-card-icon hw-icon-blue">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm0 13A6 6 0 1 1 8 2a6 6 0 0 1 0 12z"/>
                            <path d="M7.5 4a.5.5 0 0 1 .5.5v3.793l2.354 2.353a.5.5 0 0 1-.708.708L7.146 8.854A.5.5 0 0 1 7 8.5v-4a.5.5 0 0 1 .5-.5z"/>
                        </svg>
                    </div>
                    <h5 class="mt-3 fw-semibold">Blazing Fast</h5>
                    <p class="text-muted">Built on ASP.NET Core&rsquo;s high-performance runtime. Handles thousands of requests per second with minimal overhead.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="hw-card h-100">
                    <div class="hw-card-icon hw-icon-purple">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0zM4.5 7.5a.5.5 0 0 0 0 1h5.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3a.5.5 0 0 0 0-.708l-3-3a.5.5 0 1 0-.708.708L10.293 7.5H4.5z"/>
                        </svg>
                    </div>
                    <h5 class="mt-3 fw-semibold">Modern Stack</h5>
                    <p class="text-muted">Bootstrap 5, jQuery, and ASP.NET Core MVC work together seamlessly so you can focus on features, not plumbing.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="hw-card h-100">
                    <div class="hw-card-icon hw-icon-green">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/>
                        </svg>
                    </div>
                    <h5 class="mt-3 fw-semibold">Production Ready</h5>
                    <p class="text-muted">Built-in auth scaffolding, bundling, and environment configs mean you go from prototype to production without surprises.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stats -->
<section class="hw-stats py-5">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-6 col-md-3">
                <div class="hw-stat-num">10+</div>
                <div class="hw-stat-label">Years of ASP.NET</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="hw-stat-num">&#8734;</div>
                <div class="hw-stat-label">Possibilities</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="hw-stat-num">100%</div>
                <div class="hw-stat-label">Open Source</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="hw-stat-num">1</div>
                <div class="hw-stat-label">Command to Start</div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="py-5 text-center">
    <div class="container">
        <div class="hw-cta-box">
            <h2 class="fw-bold mb-2">Ready to build something?</h2>
            <p class="text-muted mb-4">Dive into the docs and start shipping your next project today.</p>
            <a href="https://learn.microsoft.com/aspnet/core" class="btn hw-btn-primary px-5">Open the Docs &rarr;</a>
        </div>
    </div>
</section>
