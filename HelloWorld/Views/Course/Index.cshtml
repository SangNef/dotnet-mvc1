@model IEnumerable<HelloWorld.Models.Course>
@{ ViewData["Title"] = "Khóa học"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Danh sách khóa học</h1>
    <a asp-action="Create" class="btn btn-primary">+ Thêm khóa học</a>
</div>

<table class="table table-bordered table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th style="width:90px">Ảnh</th>
            <th>Tiêu đề</th>
            <th>Danh mục</th>
            <th>Học phí</th>
            <th>Bắt đầu</th>
            <th>Kết thúc</th>
            <th style="width:180px"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" alt="@item.Title"
                             style="width:80px;height:55px;object-fit:cover" class="rounded"/>
                    }
                    else
                    {
                        <div class="bg-light rounded d-flex align-items-center justify-content-center"
                             style="width:80px;height:55px;font-size:11px;color:#aaa">No image</div>
                    }
                </td>
                <td>@item.Title</td>
                <td>
                    <span class="badge bg-secondary">@(item.Category?.Name ?? "—")</span>
                </td>
                <td class="text-nowrap">@item.Price.ToString("N0") ₫</td>
                <td class="text-nowrap">@item.StartDate.ToString("dd/MM/yyyy")</td>
                <td class="text-nowrap">@item.EndDate.ToString("dd/MM/yyyy")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Chi tiết</a>
                    <a asp-action="Edit"    asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                    <a asp-action="Delete"  asp-route-id="@item.Id" class="btn btn-sm btn-danger">Xóa</a>
                </td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr>
                <td colspan="7" class="text-center text-muted py-4">Chưa có khóa học nào.</td>
            </tr>
        }
    </tbody>
</table>
