@model HelloWorld.Models.Course
@{ ViewData["Title"] = Model.Title; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Chi tiết khóa học</h1>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Sửa</a>
        <a asp-action="Index" class="btn btn-secondary">← Quay lại</a>
    </div>
</div>

<div class="row g-4" style="max-width:900px">
    <div class="col-md-4">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Title"
                 class="img-fluid rounded shadow-sm" style="object-fit:cover;width:100%;max-height:220px"/>
        }
        else
        {
            <div class="bg-light rounded d-flex align-items-center justify-content-center text-muted"
                 style="height:180px">Chưa có ảnh</div>
        }

        <div class="mt-3">
            <div class="mb-2">
                <span class="text-muted small">Trạng thái</span><br/>
                @if (Model.Status == 1)
                {
                    <span class="badge bg-success">Đang hoạt động</span>
                }
                else
                {
                    <span class="badge bg-secondary">Đã xóa</span>
                }
            </div>
            <div class="mb-2">
                <span class="text-muted small">Danh mục</span><br/>
                <span class="badge bg-secondary fs-6">@(Model.Category?.Name ?? "—")</span>
            </div>
            <div class="mb-2">
                <span class="text-muted small">Học phí</span><br/>
                <strong class="text-primary fs-5">@Model.Price.ToString("N0") ₫</strong>
            </div>
            <div class="mb-2">
                <span class="text-muted small">Ngày bắt đầu</span><br/>
                <strong>@Model.StartDate.ToString("dd/MM/yyyy")</strong>
            </div>
            <div>
                <span class="text-muted small">Ngày kết thúc</span><br/>
                <strong>@Model.EndDate.ToString("dd/MM/yyyy")</strong>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <h2>@Model.Title</h2>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="text-muted">@Model.Description</p>
        }

        <hr/>

        <h5>Nội dung khóa học</h5>
        @if (!string.IsNullOrEmpty(Model.Content))
        {
            <div class="border rounded p-3 bg-white">
                @Html.Raw(Model.Content)
            </div>
        }
        else
        {
            <p class="text-muted fst-italic">Chưa có nội dung chi tiết.</p>
        }
    </div>
</div>
