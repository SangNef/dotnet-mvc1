@model HelloWorld.Models.Course
@{ ViewData["Title"] = "Xóa khóa học"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Xóa khóa học</h1>
    <a asp-action="Index" class="btn btn-secondary">← Quay lại</a>
</div>

<div class="alert alert-warning d-flex align-items-center gap-2" role="alert">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
         class="bi bi-exclamation-triangle-fill flex-shrink-0" viewBox="0 0 16 16">
        <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889
                 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0
                 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
    </svg>
    Khóa học sẽ bị <strong>ẩn khỏi danh sách</strong> (không xóa vĩnh viễn khỏi database).
</div>

<div class="card" style="max-width:600px">
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" alt="@Model.Title"
             class="card-img-top" style="max-height:200px;object-fit:cover"/>
    }
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Tiêu đề</dt>
            <dd class="col-sm-8">@Model.Title</dd>

            <dt class="col-sm-4">Danh mục</dt>
            <dd class="col-sm-8">@(Model.Category?.Name ?? "—")</dd>

            <dt class="col-sm-4">Học phí</dt>
            <dd class="col-sm-8">@Model.Price.ToString("N0") ₫</dd>

            <dt class="col-sm-4">Ngày bắt đầu</dt>
            <dd class="col-sm-8">@Model.StartDate.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-4">Ngày kết thúc</dt>
            <dd class="col-sm-8">@Model.EndDate.ToString("dd/MM/yyyy")</dd>
        </dl>
    </div>
</div>

<div class="mt-3 d-flex gap-2">
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id"/>
        <button type="submit" class="btn btn-danger px-4">Xác nhận xóa</button>
    </form>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</div>
